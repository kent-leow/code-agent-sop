# ─────────────────────────────────────────────────────────────
# Copilot Agent SOP — Credential Template
#
# Copy values into ~/.zshenv (do NOT commit real values):
#   cp .env.example ~/.zshenv.sop && cat ~/.zshenv.sop >> ~/.zshenv
# ─────────────────────────────────────────────────────────────

# ── Jira (skill: jira-ticket) ─────────────────────────────────
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
export JIRA_TOKEN=your-jira-api-token

# Your Atlassian account email
export JIRA_EMAIL=your-email@example.com

# Base URL of your Jira instance
export JIRA_BASE_URL=https://your-org.atlassian.net

# Project key (e.g. PROJ, GOBIZ)
export JIRA_PROJECT_KEY=PROJ

# ── Figma (skill: figma-design-context) ───────────────────────
# Personal access token from https://www.figma.com/settings → Personal access tokens
export FIGMA_TOKEN=your-figma-personal-access-token
